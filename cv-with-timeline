<style>
  :root {
    --ink: #0f0f0f;
    --ink-soft: #2a2a2a;
    --ink-muted: #5a5a5a;
    --ink-light: #8a8a8a;
    --accent: #1a56db;
    --accent-soft: #e8effc;
    --surface: #ffffff;
    --surface-warm: #fafaf8;
    --border: #e2e2de;
    --border-light: #eeeeea;
    --serif: 'DM Serif Display', Georgia, serif;
    --sans: 'DM Sans', -apple-system, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  @page { size: A4; margin: 0; }
  html { font-size: 15px; }
  body { font-family: var(--sans); color: var(--ink-soft); background: #e8e8e4; line-height: 1.55; -webkit-font-smoothing: antialiased; }

  @media print {
    html { font-size: 13.5px; }
    body { background: white; }
    .page { box-shadow: none !important; margin: 0 !important; }
    .print-controls { display: none !important; }
    .page + .page { page-break-before: always; }
  }

  .print-controls { position: fixed; top: 1.5rem; right: 1.5rem; z-index: 100; }
  .print-btn {
    font-family: var(--sans); font-size: 0.85rem; font-weight: 600;
    padding: 0.6rem 1.4rem; border: none; border-radius: 8px; cursor: pointer;
    background: var(--ink); color: white; box-shadow: 0 2px 12px rgba(0,0,0,0.2); transition: all 0.2s;
  }
  .print-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }

  .page { width: 210mm; min-height: 297mm; margin: 2rem auto; background: var(--surface); box-shadow: 0 4px 40px rgba(0,0,0,0.12); overflow: hidden; }
  .page-inner { padding: 2.2rem 2.4rem 1.8rem; }

  /* Header */
  .header { display: grid; grid-template-columns: 1fr auto; gap: 1rem; padding-bottom: 1.1rem; border-bottom: 2.5px solid var(--ink); margin-bottom: 1rem; }
  .header-name { font-family: var(--serif); font-size: 2.4rem; color: var(--ink); letter-spacing: -0.02em; line-height: 1.1; }
  .header-title { font-size: 0.86rem; font-weight: 500; color: var(--accent); margin-top: 0.25rem; }
  .header-contact { text-align: right; display: flex; flex-direction: column; justify-content: center; gap: 0.12rem; }
  .header-contact a, .header-contact span { font-size: 0.73rem; color: var(--ink-muted); text-decoration: none; display: block; }
  .contact-row { display: flex; justify-content: flex-end; gap: 0.85rem; margin-top: 0.12rem; }
  .contact-row a { font-size: 0.7rem; font-weight: 500; color: var(--accent); text-decoration: none; }

  /* Sections */
  .section { margin-bottom: 1rem; }
  .section-title { font-family: var(--sans); font-size: 0.63rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); padding-bottom: 0.28rem; border-bottom: 1px solid var(--border); margin-bottom: 0.55rem; }

  .summary { font-size: 0.82rem; line-height: 1.6; color: var(--ink-soft); }

  /* Highlights */
  .highlights { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.45rem; }
  .highlight-card { background: var(--surface-warm); border: 1px solid var(--border-light); border-radius: 6px; padding: 0.4rem 0.45rem; text-align: center; }
  .highlight-number { font-family: var(--serif); font-size: 1.2rem; color: var(--ink); line-height: 1.2; }
  .highlight-label { font-size: 0.6rem; color: var(--ink-light); line-height: 1.25; margin-top: 0.08rem; }

  /* Skills */
  .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.18rem 1.2rem; }
  .skill-row { display: flex; gap: 0.4rem; padding: 0.12rem 0; }
  .skill-label { font-size: 0.7rem; font-weight: 700; color: var(--ink); white-space: nowrap; min-width: 5rem; }
  .skill-value { font-size: 0.7rem; color: var(--ink-muted); line-height: 1.4; }

  /* Roles */
  .role { margin-bottom: 0.7rem; }
  .role:last-child { margin-bottom: 0; }
  .role-header { display: grid; grid-template-columns: 1fr auto; align-items: baseline; gap: 1rem; margin-bottom: 0.12rem; }
  .role-title { font-size: 0.82rem; font-weight: 700; color: var(--ink); }
  .role-company { font-weight: 400; color: var(--ink-muted); }
  .role-dates { font-size: 0.68rem; font-family: var(--mono); color: var(--ink-light); white-space: nowrap; }
  .role-tech { font-size: 0.65rem; font-family: var(--mono); color: var(--accent); margin-bottom: 0.18rem; opacity: 0.8; }
  .role-summary { font-size: 0.75rem; color: var(--ink-muted); margin-bottom: 0.18rem; line-height: 1.5; }
  .role-bullets { list-style: none; padding: 0; }
  .role-bullets li { font-size: 0.75rem; color: var(--ink-soft); padding-left: 0.85rem; position: relative; margin-bottom: 0.1rem; line-height: 1.5; }
  .role-bullets li::before { content: ''; position: absolute; left: 0.1rem; top: 0.48rem; width: 4px; height: 4px; background: var(--accent); border-radius: 50%; }
  .metric { font-weight: 600; color: var(--ink); }

  /* Page 2 */
  .page-2 .page-inner { padding-top: 1.8rem; }
  .page-2-header { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 0.45rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  .page-2-name { font-family: var(--serif); font-size: 1rem; color: var(--ink); }
  .page-2-label { font-size: 0.63rem; color: var(--ink-light); }
  .compact-role { margin-bottom: 0.5rem; }

  /* OSS */
  .oss-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem 0.85rem; }
  .oss-item { padding: 0.25rem 0; }
  .oss-name { font-size: 0.73rem; font-weight: 600; color: var(--ink); font-family: var(--mono); }
  .oss-stars { font-size: 0.62rem; font-weight: 600; color: var(--accent); background: var(--accent-soft); padding: 0.06rem 0.28rem; border-radius: 3px; }
  .oss-desc { font-size: 0.68rem; color: var(--ink-muted); line-height: 1.4; margin-top: 0.08rem; }

  /* Recognition */
  .recognition-list { display: grid; grid-template-columns: 1fr 1fr; gap: 0.1rem 1.2rem; list-style: none; }
  .recognition-list li { font-size: 0.73rem; color: var(--ink-soft); padding-left: 0.8rem; position: relative; line-height: 1.5; }
  .recognition-list li::before { content: ''; position: absolute; left: 0; top: 0.46rem; width: 4px; height: 4px; background: var(--accent); border-radius: 50%; }

  .page-footer { margin-top: 0.7rem; padding-top: 0.5rem; border-top: 1px solid var(--border); text-align: center; font-size: 0.63rem; color: var(--ink-light); }
  .page-footer a { color: var(--accent); text-decoration: none; }

  /* Timeline legend */
  .timeline-legend { display: flex; gap: 0.9rem; margin-top: 0.35rem; padding-top: 0.3rem; border-top: 1px solid var(--border-light); flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 0.25rem; font-size: 0.58rem; color: var(--ink-light); }
  .legend-dot { width: 7px; height: 7px; border-radius: 50%; }
</style>
