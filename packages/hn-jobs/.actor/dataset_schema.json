{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "hnId": {
        "type": "number",
        "description": "HN comment ID"
      },
      "company": {
        "type": "string",
        "description": "Parsed company name"
      },
      "title": {
        "type": "string",
        "description": "Parsed job title(s)"
      },
      "location": {
        "type": "string",
        "description": "Parsed location"
      },
      "isRemote": {
        "type": "boolean",
        "description": "Whether the job mentions remote work"
      },
      "isOnsite": {
        "type": "boolean",
        "description": "Whether the job mentions onsite work"
      },
      "isHybrid": {
        "type": "boolean",
        "description": "Whether the job mentions hybrid work"
      },
      "salary": {
        "type": "string",
        "description": "Salary range if mentioned"
      },
      "technologies": {
        "type": "array",
        "description": "Technologies mentioned in the post",
        "items": { "type": "string" }
      },
      "url": {
        "type": "string",
        "description": "URL included in the post"
      },
      "applyUrl": {
        "type": "string",
        "description": "Apply URL or email if different from url"
      },
      "description": {
        "type": "string",
        "description": "Full plain-text description"
      },
      "postedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of the HN comment"
      },
      "threadMonth": {
        "type": "string",
        "description": "Which monthly thread this came from (e.g. 'March 2026')"
      },
      "commentUrl": {
        "type": "string",
        "description": "Direct link to the HN comment"
      },
      "rawHtml": {
        "type": "string",
        "description": "Raw HTML from HN comment (only when includeRawHtml is enabled)",
        "nullable": true
      }
    },
    "required": [
      "hnId",
      "company",
      "location",
      "commentUrl",
      "postedAt"
    ]
  },
  "views": {
    "overview": {
      "title": "Overview",
