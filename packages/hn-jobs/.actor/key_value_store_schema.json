{
  "actorKeyValueStoreSchemaVersion": 1,
  "title": "HN Jobs Scraper Store",
  "collections": {
    "summary": {
      "title": "Run Summary",
      "description": "Summary of the scrape run including total threads, total jobs, filters applied, elapsed time, and top companies by job count.",
      "keyPrefix": "SUMMARY",
      "contentTypes": ["application/json"],
      "jsonSchema": {
        "type": "object",
        "properties": {
          "totalThreads": { "type": "integer" },
          "totalJobs": { "type": "integer" },
          "elapsedSeconds": { "type": "number" },
          "topCompanies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "jobs": { "type": "integer" }
              }
            }
          },
          "filtersApplied": { "type": "object" }
        }
      }
    }
  }
}
