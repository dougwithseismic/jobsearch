{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "company": {
        "type": "string",
        "description": "Company display name"
      },
      "companySlug": {
        "type": "string",
        "description": "BreezyHR company subdomain (e.g. 'hubstaff', 'attentive')"
      },
      "jobId": {
        "type": "string",
        "description": "Unique BreezyHR job ID"
      },
      "friendlyId": {
        "type": "string",
        "description": "Human-readable job slug"
      },
      "name": {
        "type": "string",
        "description": "Job title"
      },
      "department": {
        "type": "string",
        "description": "Department name"
      },
      "location": {
        "type": "string",
        "description": "Primary job location"
      },
      "isRemote": {
        "type": "boolean",
        "description": "Whether the job is marked as remote"
      },
      "salary": {
        "type": "string",
        "description": "Salary range (if provided by company)"
      },
      "type": {
        "type": "string",
        "description": "Employment type (Full Time, Part Time, Contract, etc.)"
      },
      "publishedDate": {
        "type": "string",
        "description": "ISO 8601 date when the job was published"
      },
      "url": {
        "type": "string",
        "description": "Direct link to the job posting on BreezyHR"
      },
      "locations": {
        "type": "array",
        "description": "All locations for this job",
        "items": {
          "type": "object",
          "properties": {
            "city": { "type": "string" },
            "region": { "type": "string" },
            "countryCode": { "type": "string" }
          }
        }
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "name",
      "location",
      "url",
      "scrapedAt"
    ]
  },
