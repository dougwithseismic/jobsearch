      },
      "country": {
        "type": "string",
        "description": "Country"
      },
      "city": {
        "type": "string",
        "description": "City"
      },
      "state": {
        "type": "string",
        "description": "State or region"
      },
      "remote": {
        "type": "boolean",
        "description": "Whether the job is remote"
      },
      "employmentType": {
        "type": "string",
        "description": "Full-time, Part-time, Contract, etc."
      },
      "tags": {
        "type": "array",
        "description": "Job tags",
        "items": { "type": "string" }
      },
      "publishedAt": {
        "type": "string",
        "description": "ISO 8601 date when the job was published"
      },
      "careersUrl": {
        "type": "string",
        "description": "URL to the careers page / apply page"
      },
      "description": {
        "type": "string",
        "description": "Full plain-text job description (only when includeDescriptions is enabled)",
        "nullable": true
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "title",
      "location",
      "remote",
      "careersUrl",
      "scrapedAt"
    ]
  },
