{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "company": {
        "type": "string",
        "description": "Company display name (board token)"
      },
      "companySlug": {
        "type": "string",
        "description": "Greenhouse board token (e.g. 'stripe', 'airbnb')"
      },
      "jobId": {
        "type": "integer",
        "description": "Unique Greenhouse job ID"
      },
      "title": {
        "type": "string",
        "description": "Job title"
      },
      "departments": {
        "type": "array",
        "description": "Department names",
        "items": { "type": "string" }
      },
      "offices": {
        "type": "array",
        "description": "Office names",
        "items": { "type": "string" }
      },
      "location": {
        "type": "string",
        "description": "Primary job location"
      },
      "updatedAt": {
        "type": "string",
        "description": "ISO 8601 date when the job was last updated"
      },
      "absoluteUrl": {
        "type": "string",
        "description": "Direct link to the job posting on Greenhouse"
      },
      "internalJobId": {
        "type": "integer",
        "description": "Internal Greenhouse job reference ID"
      },
      "metadata": {
        "type": "array",
        "description": "Custom metadata fields set by the company",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "value": {}
          }
        }
      },
      "content": {
        "type": "string",
        "description": "Full HTML job description (only when includeContent is enabled)",
        "nullable": true
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "title",
      "location",
      "absoluteUrl",
      "scrapedAt"
    ]
  },
  "views": {
    "overview": {
      "title": "Overview",
      "transformation": {
        "fields": [
          "company",
          "title",
          "departments",
          "offices",
          "location",
          "updatedAt",
          "absoluteUrl"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "company": {
            "label": "Company",
            "format": "text"
          },
          "title": {
            "label": "Job Title",
            "format": "text"
          },
          "departments": {
            "label": "Departments",
            "format": "array"
          },
          "offices": {
            "label": "Offices",
            "format": "array"
          },
          "location": {
            "label": "Location",
            "format": "text"
          },
          "updatedAt": {
            "label": "Updated",
            "format": "date"
          },
          "absoluteUrl": {
            "label": "Job URL",
            "format": "link"
          }
        }
      }
    },
    "full": {
      "title": "Full Details",
      "transformation": {
        "fields": [
          "company",
          "companySlug",
          "jobId",
          "title",
          "departments",
          "offices",
          "location",
          "internalJobId",
          "updatedAt",
          "absoluteUrl",
          "metadata",
          "scrapedAt"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "company": {
            "label": "Company",
            "format": "text"
          },
          "companySlug": {
            "label": "Slug",
            "format": "text"
          },
          "jobId": {
            "label": "Job ID",
            "format": "number"
          },
          "title": {
            "label": "Job Title",
            "format": "text"
          },
          "departments": {
            "label": "Departments",
            "format": "array"
          },
          "offices": {
            "label": "Offices",
            "format": "array"
          },
          "location": {
            "label": "Location",
            "format": "text"
          },
          "internalJobId": {
            "label": "Internal ID",
            "format": "number"
          },
          "updatedAt": {
            "label": "Updated",
            "format": "date"
          },
          "absoluteUrl": {
            "label": "Job URL",
            "format": "link"
          },
          "metadata": {
            "label": "Metadata",
            "format": "object"
          },
          "scrapedAt": {
            "label": "Scraped At",
            "format": "date"
          }
        }
      }
    }
  }
}
