{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "company": {
        "type": "string",
        "description": "Company display name (subdomain)"
      },
      "companySlug": {
        "type": "string",
        "description": "Personio subdomain (e.g. 'n26', 'celonis')"
      },
      "jobId": {
        "type": "integer",
        "description": "Unique Personio job ID"
      },
      "name": {
        "type": "string",
        "description": "Job title / position name"
      },
      "department": {
        "type": "string",
        "description": "Department name"
      },
      "office": {
        "type": "string",
        "description": "Office location"
      },
      "recruitingCategory": {
        "type": "string",
        "description": "Recruiting category (e.g. Full-time, Part-time)"
      },
      "employmentType": {
        "type": "string",
        "description": "Employment type (e.g. permanent, contract)"
      },
      "seniority": {
        "type": "string",
        "description": "Seniority level (e.g. Senior, Junior, Mid)"
      },
      "schedule": {
        "type": "string",
        "description": "Work schedule (e.g. full-time, part-time)"
      },
      "yearsOfExperience": {
        "type": "string",
        "description": "Required years of experience"
      },
      "keywords": {
        "type": "string",
        "description": "Job keywords / tags"
      },
      "occupation": {
        "type": "string",
        "description": "Occupation category"
      },
      "occupationCategory": {
        "type": "string",
        "description": "Occupation sub-category"
      },
      "createdAt": {
        "type": "string",
        "description": "ISO 8601 date when the job was created"
      },
      "jobUrl": {
        "type": "string",
        "description": "Direct link to the job posting on Personio"
      },
      "jobDescriptions": {
        "type": "array",
        "description": "Full HTML job descriptions (only when includeContent is enabled)",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "value": { "type": "string" }
          }
        }
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "name",
      "office",
      "jobUrl",
      "scrapedAt"
    ]
  },
  "views": {
