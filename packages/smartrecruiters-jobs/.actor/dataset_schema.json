        "type": "string",
        "description": "Industry label"
      },
      "function": {
        "type": "string",
        "description": "Function/category label"
      },
      "releasedDate": {
        "type": "string",
        "description": "ISO 8601 date when the job was posted"
      },
      "refNumber": {
        "type": "string",
        "description": "Job reference number"
      },
      "jobUrl": {
        "type": "string",
        "description": "URL to the job posting on SmartRecruiters"
      },
      "recruiterName": {
        "type": "string",
        "description": "Name of the recruiter who posted the job",
        "nullable": true
      },
      "description": {
        "type": "string",
        "description": "Full HTML job description (only when includeDescriptions is enabled)",
        "nullable": true
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "title",
      "city",
      "country",
      "isRemote",
      "jobUrl",
      "scrapedAt"
