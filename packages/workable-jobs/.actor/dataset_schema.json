{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "company": {
        "type": "string",
        "description": "Company display name"
      },
      "companySlug": {
        "type": "string",
        "description": "Workable job board slug (e.g. '1000heads', 'typeform')"
      },
      "shortcode": {
        "type": "string",
        "description": "Unique Workable job shortcode"
      },
      "title": {
        "type": "string",
        "description": "Job title"
      },
      "department": {
        "type": "string",
        "description": "Department name"
      },
      "employmentType": {
        "type": "string",
        "description": "Full-time, Part-time, Contract, etc."
      },
      "isRemote": {
        "type": "boolean",
        "description": "Whether the job allows telecommuting"
      },
      "country": {
        "type": "string",
        "description": "Primary country"
      },
      "city": {
        "type": "string",
        "description": "Primary city"
      },
      "state": {
        "type": "string",
        "description": "Primary state/region"
      },
      "locations": {
        "type": "array",
        "description": "All locations for the role",
        "items": {
          "type": "object",
          "properties": {
            "country": { "type": "string" },
            "countryCode": { "type": "string" },
            "city": { "type": "string" },
            "region": { "type": "string" }
          }
        }
      },
      "experience": {
        "type": "string",
        "description": "Experience level (e.g. 'Mid-Senior level', 'Director')"
      },
      "industry": {
        "type": "string",
        "description": "Industry category"
      },
      "publishedAt": {
        "type": "string",
        "description": "Date when the job was published (YYYY-MM-DD)"
      },
      "jobUrl": {
        "type": "string",
        "description": "URL to the job posting on Workable"
      },
      "applyUrl": {
        "type": "string",
        "description": "Direct application URL"
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "shortcode",
      "title",
      "isRemote",
      "jobUrl",
      "applyUrl",
      "scrapedAt"
    ]
  },
