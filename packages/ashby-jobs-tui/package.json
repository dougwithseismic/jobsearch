{
  "name": "ashby-jobs-tui",
  "version": "1.0.0",
  "description": "Interactive terminal UI for browsing Ashby job boards",
  "type": "module",
  "bin": {
    "ashby-tui": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/cli.ts",
    "start": "node bin/cli.js",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "ashby-jobs": "workspace:*",
    "clipboardy": "^5.3.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
