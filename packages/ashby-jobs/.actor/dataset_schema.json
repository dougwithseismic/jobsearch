{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "company": {
        "type": "string",
        "description": "Company display name"
      },
      "companySlug": {
        "type": "string",
        "description": "Ashby job board slug (e.g. 'linear', 'notion')"
      },
      "jobId": {
        "type": "string",
        "description": "Unique Ashby job ID"
      },
      "title": {
        "type": "string",
        "description": "Job title"
      },
      "department": {
        "type": "string",
        "description": "Department name"
      },
      "team": {
        "type": "string",
        "description": "Team within the department"
      },
      "employmentType": {
        "type": "string",
        "description": "Full-time, Part-time, Contract, etc."
      },
      "location": {
        "type": "string",
        "description": "Primary job location"
      },
      "secondaryLocations": {
        "type": "array",
        "description": "Additional locations for the role",
        "items": { "type": "string" }
      },
      "isRemote": {
        "type": "boolean",
        "description": "Whether the job is remote"
      },
      "workplaceType": {
        "type": "string",
        "description": "On-site, Remote, or Hybrid"
      },
      "publishedAt": {
        "type": "string",
        "description": "ISO 8601 date when the job was published"
      },
      "jobUrl": {
        "type": "string",
        "description": "URL to the job posting on Ashby"
      },
      "applyUrl": {
        "type": "string",
        "description": "Direct application URL"
      },
      "compensationTierSummary": {
        "type": "string",
        "description": "Salary/compensation summary if available",
        "nullable": true
      },
      "country": {
        "type": "string",
        "description": "Country from postal address",
        "nullable": true
      },
      "region": {
        "type": "string",
        "description": "Region/state from postal address",
        "nullable": true
      },
      "city": {
        "type": "string",
        "description": "City from postal address",
        "nullable": true
      },
      "description": {
        "type": "string",
        "description": "Full plain-text job description (only when includeDescriptions is enabled)",
        "nullable": true
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "title",
      "location",
      "isRemote",
      "jobUrl",
      "applyUrl",
      "scrapedAt"
    ]
  },
  "views": {
    "overview": {
      "title": "Overview",
