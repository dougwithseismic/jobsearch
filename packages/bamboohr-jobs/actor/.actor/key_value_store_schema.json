{
  "actorKeyValueStoreSchemaVersion": 1,
  "title": "BambooHR Jobs Scraper Store",
  "collections": {
    "summary": {
      "title": "Run Summary",
      "description": "Summary with total companies, total jobs, elapsed time, filters applied, and top companies by job count",
      "key": "SUMMARY",
      "contentTypes": ["application/json"],
      "jsonSchema": {
        "type": "object",
        "properties": {
          "scrapedAt": { "type": "string" },
          "elapsedSeconds": { "type": "number" },
          "mode": { "type": "string" },
          "totalCompanies": { "type": "integer" },
          "totalJobs": { "type": "integer" }
        }
      }
    }
  }
}
