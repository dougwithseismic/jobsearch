{
  "actorKeyValueStoreSchemaVersion": 1,
  "title": "deadlyaccuratejobs Store",
  "collections": {
    "summary": {
      "title": "Run Summary",
      "description": "Summary with company name, matched ATS platforms, total jobs, filtered jobs, elapsed time",
      "key": "SUMMARY",
      "contentTypes": ["application/json"],
      "jsonSchema": {
        "type": "object",
        "properties": {
          "company": { "type": "string" },
          "matches": { "type": "array" },
          "totalJobs": { "type": "integer" },
          "filteredJobs": { "type": "integer" },
          "scrapedAt": { "type": "string" },
          "duration": { "type": "number" }
        }
      }
    }
  }
}
