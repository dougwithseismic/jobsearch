{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "company": {
        "type": "string",
        "description": "Company display name (slug)"
      },
      "companySlug": {
        "type": "string",
        "description": "Lever job board slug (e.g. 'netflix', 'spotify')"
      },
      "jobId": {
        "type": "string",
        "description": "Unique Lever posting ID"
      },
      "title": {
        "type": "string",
        "description": "Job title"
      },
      "department": {
        "type": "string",
        "description": "Department name"
      },
      "team": {
        "type": "string",
        "description": "Team within the department"
      },
      "commitment": {
        "type": "string",
        "description": "Full-time, Part-time, Contract, Intern, etc."
      },
      "location": {
        "type": "string",
        "description": "Primary job location"
      },
      "allLocations": {
        "type": "array",
        "description": "All locations for the role",
        "items": { "type": "string" }
      },
      "workplaceType": {
        "type": "string",
        "description": "unspecified, on-site, remote, or hybrid"
      },
      "hostedUrl": {
        "type": "string",
        "description": "URL to the job posting on Lever"
      },
      "applyUrl": {
        "type": "string",
        "description": "Direct application URL"
      },
      "createdAt": {
        "type": "string",
        "description": "ISO 8601 date when the job was created"
      },
      "description": {
        "type": "string",
        "description": "Full plain-text job description (only when includeDescriptions is enabled)",
        "nullable": true
      },
      "scrapedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when this job was scraped"
      }
    },
    "required": [
      "company",
      "companySlug",
      "jobId",
      "title",
      "location",
      "hostedUrl",
      "applyUrl",
      "scrapedAt"
    ]
  },
  "views": {
    "overview": {
      "title": "Overview",
      "transformation": {
        "fields": [
          "company",
          "title",
          "department",
          "location",
          "commitment",
          "workplaceType",
          "createdAt",
          "hostedUrl"
        ]
      },
